# ISKA Project .gitignore

# --- Specific Project Files ---
# Ignore the local SQLite database
iska_database.db
gemmatest.py
mic_check.py
.zip
settings.json
pup_logo.png

# Ignore the Vosk model directory (add your specific folder name if different)
vosk-model-*/
vosk/
model/

# Ignore temporary audio files generated by the TTS engine
temp_response_*.mp3

# --- Python Environment ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# --- Environment Secrets ---
# If you ever use a .env file for secret keys
.env

# --- OS Specific Files ---
.DS_Store
Thumbs.db

# --- Vosk Model Assets ---
# Ignore the entire model directory
model/

# Specific Vosk binary and configuration extensions 
*.mdl
*.fst
*.conf
*.int
*.dubm
*.ie
*.mat
*.stats